          "content": {
            "size": 3404,
            "mimeType": "text/html",
            "text": "<!DOCTYPE html>\n\n<html lang=\"pt-br\">\n  <head>\n    <meta charset=\"utf-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\" />\n    <title>Bem-vindo ao Modoboa</title>\n    <link rel=\"icon\" type=\"image/x-icon\" href=\"/sitestatic/css/favicon.ico\" />\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"/sitestatic/css/offline.css\" />\n    <style>\n     .left-column {\n       background-color: #000101;\n       text-align: center;\n     }\n     .btn-primary {\n       background-color: #000101;\n       color: white;\n     }\n     .btn-primary:hover {\n       background-color: #0350BA;\n     }\n     .footer a {\n       color: ##000101;\n       text-decoration: none;\n       font-size: 14px;\n     }\n    </style>\n    \n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/sitestatic/css/login.css\" />\n\n  </head>\n  <body>\n    <div class=\"container\">\n      <div class=\"column left-column\">\n        <a href=\"#\" class=\"logo\">\n          <img src=\"/sitestatic/css/modoboa-white.png\" />\n        </a>\n        \n  \n\n      </div>\n      <div class=\"column right-column\">\n        \n  <div class=\"login-box\">\n    <h2>Identificação</h2>\n    <form method=\"post\" action=\"/accounts/login/\" class=\"login-form form-horizontal\">\n      <input type=\"hidden\" name=\"csrfmiddlewaretoken\" value=\"ZlgdC967Bkb6rz66wVubumqtTSXsS02n1VTD3TdwIGgc4Qb4k2aMa37spC8b66mi\">\n      <div class=\"input-group\">\n        \n<div class=\"form-group\n    \n    \"\n    \n>\n\n  \n  <label class=\"control-label col-sm-4\" for=\"id_username\">Username\n    \n  </label>\n  \n\n  <div class=\"col-sm-5\">\n    \n      <input type=\"text\" name=\"username\" autofocus autocapitalize=\"none\" autocomplete=\"username\" maxlength=\"254\" class=\"form-control\" required id=\"id_username\">\n      \n    \n    \n    \n  </div>\n\n  \n\n  \n  \n\n</div>\n\n      </div>\n      <div class=\"input-group\">\n        \n<div class=\"form-group\n    \n    \"\n    \n>\n\n  \n  <label class=\"control-label col-sm-4\" for=\"id_password\">Senha\n    \n  </label>\n  \n\n  <div class=\"col-sm-5\">\n    \n      <input type=\"password\" name=\"password\" autocomplete=\"current-password\" class=\"form-control\" required id=\"id_password\">\n      \n    \n    \n    \n  </div>\n\n  \n\n  \n  \n\n</div>\n\n      </div>\n      <input type=\"hidden\" name=\"next\" value=\"/api/o/authorize/?client_id=bc2c4172-f53c-4b9d-aa80-662d9d689be4&amp;redirect_uri=https%3A%2F%2Fmail.sintraffms.com%2Flogin%2Flogged&amp;response_type=code&amp;scope=openid+read+write&amp;state=75546291b1e14552ab61bf08155886d2&amp;code_challenge=5qrBhG_YKZk2nNl34ovxP__9HwWM3gHzR0jaFDM9ITQ&amp;code_challenge_method=S256\" />\n\n      <div class=\"input-group checkbox-group\">\n        <input type=\"checkbox\" id=\"remember\" name=\"remember\">\n        <label for=\"remember\">Lembrar-me</label>\n      </div>\n      <button class=\"btn btn-primary\" type=\"submit\">Entrar</button>\n    </form>\n    <div class=\"footer\">\n      <a class=\"pull-right\" href=\"/accounts/password_reset/\">Esqueceu a senha?</a>\n    </div>\n    \n  </div>\n\n      </div>\n    </div>\n    \n  <script type=\"text/javascript\">\n  document.addEventListener('DOMContentLoaded', () => {\n    const form = document.querySelector('form');\n    const field = document.querySelector('#id_username');\n    field.focus();\n    form.addEventListener('submit', () => {\n      const submitBtn = document.querySelector('button[type=submit]');\n      submitBtn.disabled = true;\n    });\n  });\n  </script>\n\n  </body>\n</html>\n"
          },
