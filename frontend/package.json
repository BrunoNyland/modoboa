    "@tiptap/starter-kit": "^3.11.0",
    "@tiptap/vue-3": "^3.11.0",
    "apexcharts": "^5.3.5",
    "axios": "^1.15.2",
    "debounce": "^2.1.0",
    "filesize": "^10.1.6",
    "js-cookie": "^3.0.5",
    "luxon": "^3.4.4",
